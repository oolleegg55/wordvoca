<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WordVoca.App.Pages.Exercises.WordCardsExerciseView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WordVoca.App.Pages.Exercises"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    Title="Word Cards"
    x:DataType="vm:WordCardsExerciseVm">
    <Grid RowDefinitions="*,Auto" Padding="10">
        <StackLayout Grid.Row="0">
            <Label Text="{Binding CurrentWord.Value}"
                   HorizontalOptions="Center"
                   FontSize="28"/>
            <Label Text="{Binding CurrentWord.Note}"
                   HorizontalOptions="Center"
                   FontSize="18"
                   Padding="0,5,0,0"
                   IsVisible="{Binding HasNote}"/>
            <Button Command="{Binding PlayAudioCommand}"
                    ImageSource="{mi:Fluent Icon=HeadphonesSoundWave28, IconColor=White}"
                    WidthRequest="50"
                    HeightRequest="50"
                    Margin="0,30,0,0"/>

            <BoxView HeightRequest="1"
                     Margin="0,75,0,20"
                     Color="LightGray"/>
            <Label Text="{Binding CurrentWord.Translation}"
                   HorizontalOptions="Center"
                   FontSize="26"/>
        </StackLayout>

        <StackLayout Grid.Row="1"
                     HorizontalOptions="Center"
                     Orientation="Horizontal"
                     Spacing="10">
            <HorizontalStackLayout IsVisible="{Binding IsNotLastWord}"
                                   Spacing="10">
                <Button Command="{Binding MoveToPreviousWordCommand}"
                        Text="Previous"
                        WidthRequest="125"
                        ContentLayout="Left"
                        IsVisible="{Binding IsNotFirstWord}"
                        ImageSource="{mi:Fluent Icon=ArrowLeft12,IconSize=Medium}" />

                <Button Command="{Binding MoveToNextWordCommand}"
                        Text="Next"
                        WidthRequest="125"
                        ContentLayout="Right"
                        ImageSource="{mi:Fluent Icon=ArrowRight16, IconSize=Medium}" />
            </HorizontalStackLayout>

            <StackLayout IsVisible="{Binding IsLastWord}">
                <Button Text="Next exercise" />
            </StackLayout>
        </StackLayout>

    </Grid>
</ContentPage>