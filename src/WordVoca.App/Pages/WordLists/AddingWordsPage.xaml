<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WordVoca.App.Pages.WordLists.AddingWordsPage"
             xmlns:local="clr-namespace:WordVoca.App.Pages.WordLists"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:model="clr-namespace:WordVoca.Core.Models;assembly=WordVoca.Core"
             x:DataType="local:AddingWordsPageVm"
             Title="Adding word(s)">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto,*,Auto"
              Margin="10">
            <StackLayout Grid.Row="0"
                    Margin="5">
                <Label Text="Word"/>
                <Entry Text="{Binding Word}"
                       Placeholder="New word"/>

                <Label Text="Translation"/>
                <Entry Text="{Binding Translation}"
                       Placeholder="Translation"/>

                <Label Text="Note"/>
                <Entry Text="{Binding Note}"
                       Placeholder="Note"/>

                <Button Text="Add"
                        Command="{Binding AddWordCommand}"
                        HorizontalOptions="Start"
                        WidthRequest="75"
                        Margin="0,10,0,10"
                        HeightRequest="45"/>
                <Label Text="Words"
                        Margin="0,0,0,10"
                        FontAttributes="Bold"
                        FontSize="18"/>
            </StackLayout>
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Words}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                            ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Word">
                        <Border Padding="10"
                                Stroke="DarkBlue">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout Spacing="5">
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Value}"/>
                                            <Span Text=" - "/>
                                            <Span Text="{Binding Translation}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding Note}"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Grid.Row="2"
                    Text="Add words to list"
                    WidthRequest="175"
                    HorizontalOptions="Center"
                    CornerRadius="10"
                    Margin="10"
                    Command="{Binding AddWordsToListCommand}"/>
        </Grid>
    </ContentPage.Content>
</ContentPage>
