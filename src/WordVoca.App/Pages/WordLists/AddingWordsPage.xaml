<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WordVoca.App.Pages.WordLists.AddingWordsPage"
             xmlns:local="clr-namespace:WordVoca.App.Pages.WordLists"
             x:DataType="local:AddingWordsPageVm"
             Title="Adding word(s)">
    <ContentPage.Content>
        <Grid RowDefinitions="*,Auto">
            <StackLayout Grid.Row="0">
                <Label Text="Word" />
                <Entry Text="{Binding AddWordsCommand}" Placeholder="New word" />

                <Label Text="Translation" />
                <Entry Text="{Binding Translation}" Placeholder="Translation" />

                <Label Text="Note" />
                <Entry Text="{Binding Note}" Placeholder="Note" />
            </StackLayout>
            <Button Grid.Row="1"
                    Text="Add"
                    WidthRequest="175"
                    HorizontalOptions="Center"
                    CornerRadius="10"
                    Margin="10" />
        </Grid>
    </ContentPage.Content>
</ContentPage>