<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="WordVoca.App.Pages.WordLists.WordListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WordVoca.App.Pages.WordLists"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:model="clr-namespace:WordVoca.Core.Models;assembly=WordVoca.Core"
    Title="{Binding WordListName}"
    x:DataType="local:WordListPageVm"
    Loaded="HandlePageLoaded">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="{mi:Fluent Icon=Info24, IconColor=DarkBlue}" />
        <ToolbarItem Command="{Binding GoToAddingWordsPageCommand}" IconImageSource="{mi:Fluent Icon=Add24, IconColor=DarkBlue}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <Grid Margin="10" RowDefinitions="*,Auto">
            <StackLayout Grid.Row="0">
                <CollectionView ItemsSource="{Binding Words}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Word">
                            <Border Padding="10,10,10,10" Stroke="DarkBlue">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackLayout Grid.Column="0">
                                        <Label Text="{Binding Value}" />
                                        <Label Text="{Binding Translation}" />
                                        <Label Text="{Binding Note}" />
                                    </StackLayout>
                                    <Button
                                        Grid.Column="1"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:WordListPage}}, Path=BindingContext.PlayWordAudioCommand}"
                                        CommandParameter="{Binding Value}"
                                        HeightRequest="40"
                                        ImageSource="{mi:Fluent Icon=HeadphonesSoundWave28,
                                                                IconBackgroundColor=DarkBlue}"
                                        WidthRequest="40" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
            <StackLayout
                Grid.Row="1"
                Margin="0,10,0,0"
                HorizontalOptions="Center">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        Text="List"
                        WidthRequest="75" />
                    <Button
                        Grid.Column="1"
                        Text="Learn"
                        WidthRequest="75" />
                </Grid>
            </StackLayout>
        </Grid>
    </ContentPage.Content>

</ContentPage>