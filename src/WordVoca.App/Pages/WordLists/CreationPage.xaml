<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WordVoca.App.Pages.WordLists.CreationPage"
             xmlns:local="clr-namespace:WordVoca.App.Pages.WordLists"
             Shell.FlyoutBehavior="Disabled">
    <ContentPage.BindingContext>
        <local:CreationPageVm />
    </ContentPage.BindingContext>
    <ContentPage.Content>
        <Grid RowDefinitions="*,Auto">
            <StackLayout Grid.Row="0">
                <StackLayout>
                    <Label Text="Name" />
                    <Entry Text="{Binding WordListName}" />
                </StackLayout>

                <StackLayout>
                    <Label Text="Source language"/>
                    <Picker
                        Title="Select language"
                        ItemsSource="{Binding AllLangs}"
                        SelectedItem="{Binding SourceLang, Mode=TwoWay}">
                    </Picker>
                </StackLayout>

                <StackLayout>
                    <Label Text="Target language" />
                    <Picker
                        Title="Select language"
                        ItemsSource="{Binding AllLangs}"
                        SelectedIndex="1"
                        SelectedItem="{Binding TargetLang, Mode=TwoWay}">
                    </Picker>
                </StackLayout>
            </StackLayout>

            <StackLayout HorizontalOptions="Center" Grid.Row="1" Padding="0,0,0,10">
                <Button Command="{Binding CreateCommand}" Text="Create"/>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>