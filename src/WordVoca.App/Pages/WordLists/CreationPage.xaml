<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WordVoca.App.Pages.WordLists.CreationPage"
             Shell.FlyoutBehavior="Disabled">
    <ContentPage.Content>
        <Grid RowDefinitions="*,Auto">
            <StackLayout Grid.Row="0">
                <StackLayout>
                    <Label Text="Name" />
                    <Entry />
                </StackLayout>

                <StackLayout>
                    <Label Text="Source language"></Label>
                    <Picker
                        Title="Select language">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>EN</x:String>
                                <x:String>ES</x:String>
                                <x:String>RU</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </StackLayout>

                <StackLayout>
                    <Label Text="Target language" />
                    <Picker
                        Title="Select language">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>EN</x:String>
                                <x:String>ES</x:String>
                                <x:String>RU</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </StackLayout>
            </StackLayout>

            <StackLayout HorizontalOptions="Center" Grid.Row="1" Padding="0,0,0,10">
                <Button Text="Create"/>
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>