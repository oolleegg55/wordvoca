<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="WordVoca.App.Pages.WordLists.CreationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:WordVoca.App.Pages.WordLists"
    Title="Word List Creation"
    x:DataType="local:CreationPageVm">
    <ContentPage.Content>
        <Grid Margin="10,0,10,0" RowDefinitions="*,Auto">
            <VerticalStackLayout Grid.Row="0">
                <StackLayout Margin="0,0,0,10">
                    <Label
                        FontSize="18"
                        Text="Name"
                        TextColor="{DynamicResource PrimaryDarkText}" />
                    <Entry
                        FontSize="18"
                        Placeholder="{Binding WordListDefaultName}"
                        Text="{Binding WordListName}" />
                </StackLayout>

                <StackLayout Margin="0,10,0,10" HorizontalOptions="Start">
                    <Label
                        FontSize="18"
                        Text="Source language"
                        TextColor="{DynamicResource PrimaryDarkText}" />
                    <Picker
                        Title="Select language"
                        FontSize="18"
                        ItemsSource="{Binding AllLangs}"
                        SelectedItem="{Binding SourceLang, Mode=TwoWay}"
                        WidthRequest="175" />
                </StackLayout>

                <StackLayout Margin="0,10,0,0" HorizontalOptions="Start">
                    <Label
                        FontSize="18"
                        Text="Target language"
                        TextColor="{DynamicResource PrimaryDarkText}" />
                    <Picker
                        Title="Select language"
                        FontSize="18"
                        ItemsSource="{Binding AllLangs}"
                        SelectedItem="{Binding TargetLang, Mode=TwoWay}"
                        WidthRequest="175" />
                </StackLayout>
            </VerticalStackLayout>

            <StackLayout
                Grid.Row="1"
                Padding="0,0,0,10"
                HorizontalOptions="Center">
                <Button
                    Command="{Binding CreateCommand}"
                    FontSize="20"
                    Text="Create"
                    WidthRequest="250" />
            </StackLayout>
        </Grid>
    </ContentPage.Content>
</ContentPage>
