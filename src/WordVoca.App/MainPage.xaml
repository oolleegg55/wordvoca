<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WordVoca.App.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
     xmlns:viewmodels="clr-namespace:WordVoca.App.ViewModels"
    xmlns:local="clr-namespace:WordVoca.App"
    x:DataType="local:MainPage"
    Shell.FlyoutBehavior="Disabled">
    <Grid RowDefinitions="Auto,*">
        <Grid
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*,48"
            Grid.Row="0"
            Margin="0"
            Padding="10,0"
            HorizontalOptions="Fill"
            VerticalOptions="Center">
            <Button
                Grid.Column="0"
                Grid.Row="0"
                Padding="0"
                HeightRequest="48"
                SemanticProperties.Hint="Open menu"
                WidthRequest="48" />
            <Label
                Grid.Column="1"
                Grid.Row="0"
                FontSize="22"
                HorizontalOptions="Center"
                Text="Word Voca"
                TextColor="#1D3557"
                VerticalOptions="Center" />
            <Button
                Grid.Column="2"
                Grid.Row="0"
                HeightRequest="48"
                WidthRequest="48" />
            <Label
                Grid.Column="1"
                Grid.Row="1"
                FontSize="14"
                HorizontalOptions="Center"
                Text="Create your word lists with ease!"
                TextColor="#1D3557"
                VerticalOptions="Center"/>
        </Grid>
        <CollectionView Grid.Row="1" Background="Beige" ItemsSource="{Binding WordListViewModels}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:WordListViewModel">
                    <Border Stroke="Black">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="Auto,*,Auto"
                              Margin="0"
                              Padding="30,10">
                            <Label Grid.Row="0"
                                   Grid.Column="0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding SourceLang}"/>
                                        <Span Text="-"/>
                                        <Span Text="{Binding TargetLang}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding Name}"/>
                            <Label Grid.Row="1"
                                   Grid.Column="3"
                                   Text="{Binding WordCount}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
