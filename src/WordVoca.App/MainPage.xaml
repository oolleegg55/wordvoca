<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WordVoca.App.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:WordVoca.App.ViewModels"
    xmlns:model="clr-namespace:WordVoca.Core.Models;assembly=WordVoca.Core"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:local="clr-namespace:WordVoca.App"
    x:DataType="viewmodels:WordListViewModel"
    Shell.FlyoutBehavior="Disabled">
    <Grid RowDefinitions="Auto,*" Margin="0" Padding="0">
        <Grid
            RowDefinitions="*,Auto"
            ColumnDefinitions="48,*,48"
            Grid.Row="0"
            Padding="0"
            Margin="5">
            <Button
                Grid.Column="0"
                Grid.Row="0"
                Padding="0"
                HeightRequest="48"
                SemanticProperties.Hint="Open menu"
                ImageSource="{mi:Fluent Icon=Navigation24, IconColor=DarkBlue}"
                BackgroundColor="White"
                WidthRequest="48" />
            <Label
                Grid.Column="1"
                Grid.Row="0"
                FontSize="22"
                HorizontalOptions="Center"
                Text="Word Voca"
                TextColor="#1D3557"
                VerticalOptions="Center" />
            <Button
                Grid.Column="2"
                Grid.Row="0"
                HeightRequest="64"
                WidthRequest="64"
                ImageSource="{mi:Fluent Icon=Add28, IconColor=DarkBlue}"
                BackgroundColor="Transparent"/>
            <Label
                Grid.Column="1"
                Grid.Row="1"
                FontSize="14"
                HorizontalOptions="Center"
                Text="Create your word lists with ease!"
                FontAttributes="Bold"
                TextColor="#1D3557"
                VerticalOptions="Center"/>
        </Grid>
        <CollectionView Grid.Row="1" ItemsSource="{Binding WordLists}" Margin="0,25">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:WordList">
                    <VerticalStackLayout Spacing="0" Padding="0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                          Margin="2.5"
                          Padding="30,5">
                            <VerticalStackLayout Grid.Column="0"
                                                 Grid.Row="0">
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SourceLang}" TextTransform="Lowercase"/>
                                            <Span Text="-"/>
                                            <Span Text="{Binding TargetLang}" TextTransform="Lowercase"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   Padding="0,7.5"/>
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="2"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Spacing="2.5">
                                <Label VerticalOptions="Center"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       Margin="0"
                                       Text="{Binding WordsCount}"/>
                                <mi:MauiIcon Icon="{mi:Fluent Icon=CaretRight24}"
                                             IconColor="Black"
                                             WidthRequest="24"
                                             HeightRequest="24"
                                             VerticalOptions="Center"
                                             Padding="0,-2.5"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1"
                                 Color="#E0E0E0"
                                 HorizontalOptions="Fill"
                                 Margin="16,0,16,0"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
