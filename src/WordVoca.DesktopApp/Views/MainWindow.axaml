<Window xmlns="https://github.com/avaloniaui"
        xmlns:avalonia="using:FluentIcons.Avalonia"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WordVoca.DesktopApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:WordVoca.Core.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="WordVoca.DesktopApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="WordVoca">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="Auto,*"
          ColumnSpacing="25"
          Margin="10,5,10,5">
        <StackPanel Grid.Column="0"
                    Width="200">
            <Border CornerRadius="5"
                    BorderBrush="DimGray"
                    BorderThickness=".2"
                    Padding="10"
                    BoxShadow="0 2 2 0 Gray">
                <StackPanel Spacing="10">
                    <Button HorizontalAlignment="Stretch"
                            Background="#202233"
                            Foreground="#fff"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <avalonia:FluentIcon Icon="AddCircle" />
                            <Label Content="New word list"/>
                        </StackPanel>
                    </Button>

                    <Line StartPoint="0,0"
                          EndPoint="180,0"
                          Stroke="Gray"
                          Margin="0,5,0,5"/>

                    <Button HorizontalAlignment="Stretch"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <avalonia:FluentIcon Icon="ListBar" />
                            <Label Content="All word lists"/>
                        </StackPanel>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <avalonia:FluentIcon Icon="StackStar" />
                            <Label Content="Favorites"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="25">
            <Border CornerRadius="5"
                    BorderBrush="DimGray"
                    BorderThickness=".2"
                    Padding="10"
                    BoxShadow="0 2 2 0 Gray">
                <StackPanel>
                    <StackPanel HorizontalAlignment="Left"
                                Orientation="Horizontal">
                        <avalonia:FluentIcon Icon="ListBar"/>
                        <Label>All word lists</Label>
                    </StackPanel>
                    <Border Background="LightGray"
                            HorizontalAlignment="Stretch"
                            Padding="5">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="20">
                            <TextBox Width="250" PlaceholderText="Word list name"/>
                            <TextBox Width="250" PlaceholderText="Find word"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding WordLists}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:WordList">
                        <Border BorderBrush="{DynamicResource ResourceKey=Gray200}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10,5,10,5"
                                HorizontalAlignment="Stretch">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch">
                                    <StackPanel HorizontalAlignment="Left"
                                                Orientation="Horizontal">
                                        <avalonia:FluentIcon Icon="Star" Margin="0,0,5,0"/>
                                        <Label Content="{Binding Name}" />
                                    </StackPanel>

                                    <StackPanel HorizontalAlignment="Right">
                                        <StackPanel Background="LightGray">
                                            <TextBlock>
                                                <Run Text="{Binding SourceLang, Converter={StaticResource Lowercase}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Window>
